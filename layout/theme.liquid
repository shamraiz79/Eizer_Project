  {% endif %}

  <link rel="icon" href="{{ 'favicon.png' | asset_url }}" type="image/png" />

  {{ content_for_header }}

  {{ 'style.css' | asset_url | stylesheet_tag }} {{ 'font-awesome.min.css' | asset_url | stylesheet_tag }}
  {{ 'themify-icons.css' | asset_url | stylesheet_tag }}
  {{ 'flaticon.css' | asset_url | stylesheet_tag }}
  {{ 'owl.carousel.min.css' | asset_url | stylesheet_tag }}
  {{ 'simpleLightbox.css' | asset_url | stylesheet_tag }}
  {{ 'nice-select.css' | asset_url | stylesheet_tag }}
  {{ 'animate.css' | asset_url | stylesheet_tag }}
  {{ 'jquery-ui.css' | asset_url | stylesheet_tag }}
  
  {{ 'main-style.css' | asset_url | stylesheet_tag }} {{ 'responsive.css' | asset_url | stylesheet_tag }}
{{ 'style.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lykmapipo/themify-icons@0.1.2/css/themify-icons.css">

</head>

<body>
  {% section 'top-menu' %}
  {% section 'header' %}

  <main role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <script src="{{ 'jquery-3.2.1.min.js' | asset_url }}" defer></script>
  <script src="{{ 'stellar.js' | asset_url }}" defer></script>
  <script src="{{ 'simpleLightbox.min.js' | asset_url }}" defer></script>
  <script src="{{ 'jquery.nice-select.min.js' | asset_url }}" defer></script>
  <script src="{{ 'imagesloaded.pkgd.min.js' | asset_url }}" defer></script>
  <script src="{{ 'isotope-min.js' | asset_url }}" defer></script>
  <script src="{{ 'owl.carousel.min.js' | asset_url }}" defer></script>
  <script src="{{ 'jquery.ajaxchimp.min.js' | asset_url }}" defer></script>
  <script src="{{ 'jquery.waypoints.min.js' | asset_url }}" defer></script>
  <script src="{{ 'jquery.counterup.js' | asset_url }}" defer></script>
  <script src="{{ 'mail-script.js' | asset_url }}" defer></script>
  <script src="{{ 'theme.js' | asset_url }}" defer></script>


  <div class="cart-drawer-overlay" id="CartDrawerOverlay"></div>

<div class="cart-drawer" id="CartDrawer">
  <div class="cart-drawer-header">
    <h3>Your Cart</h3>
    <button class="cart-drawer-close" id="CartDrawerClose">&times;</button>
  </div>

  <div class="cart-drawer-body" id="CartDrawerBody">
    </div>

  <div class="cart-drawer-footer">
    <div class="cart-drawer-subtotal">
      <span>Subtotal</span>
      <span id="CartDrawerTotal">$0.00</span>
    </div>
    <p class="cart-drawer-tax-note">Taxes and shipping calculated at checkout.</p>
    <form action="/cart" method="post" novalidate class="cart-drawer-form">
      <button type="submit" name="checkout" class="main-btn drawer-checkout-btn">Checkout</button>
    </form>
  </div>
</div>

{% comment %} search drawer {% endcomment %}
 <div class="search-overlay" id="SearchOverlay">
  <button class="search-close-btn" id="SearchCloseBtn">&times;</button>
  
  <div class="search-overlay-content">
    <form action="{{ routes.search_url }}" method="get" class="search-overlay-form">
      <input type="hidden" name="type" value="product"> 
      
      <input type="text" name="q" placeholder="What are you looking for?" class="search-overlay-input" id="SearchInput" autocomplete="off">
      <button type="submit" class="search-overlay-submit"><i class="ti-search"></i></button>
    </form>
    <p class="search-hint">Hit enter to search or ESC to close</p>
  </div>
</div>
</body>
</html>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const searchTrigger = document.getElementById('SearchTrigger');
    const searchOverlay = document.getElementById('SearchOverlay');
    const searchCloseBtn = document.getElementById('SearchCloseBtn');
    const searchInput = document.getElementById('SearchInput');

    // 1. Open the Overlay
    if(searchTrigger && searchOverlay) {
      searchTrigger.addEventListener('click', function(e) {
        e.preventDefault(); // Stop standard link behavior
        searchOverlay.classList.add('is-active');
        document.body.style.overflow = 'hidden'; // Stop background scrolling
        
        // Auto-focus the input box after the CSS animation finishes
        setTimeout(() => {
          searchInput.focus();
        }, 300);
      });
    }

    // 2. Close the Overlay
    function closeSearch() {
      searchOverlay.classList.remove('is-active');
      document.body.style.overflow = ''; 
    }

    if(searchCloseBtn) {
      searchCloseBtn.addEventListener('click', closeSearch);
    }

    // 3. Close on hitting the "ESC" key on a keyboard
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && searchOverlay.classList.contains('is-active')) {
        closeSearch();
      }
    });
  });
</script>