<section class="banner_area" style="background: #f9f9fa; padding: 60px 0; margin-bottom: 50px;">
  <div class="banner_inner d-flex align-items-center">
    <div class="container">
      <div class="banner_content d-md-flex justify-content-between align-items-center">
        <div class="mb-3 mb-md-0">
          <h2 style="color: #222; font-size: 36px; font-weight: 700;">{{ collection.title }}</h2>
        </div>
        <div class="page_link" style="font-size: 12px; text-transform: uppercase; letter-spacing: 1px;">
          <a href="{{ routes.root_url }}" style="color: #777; text-decoration: none;">Home</a> / 
          <a href="{{ routes.all_products_collection_url }}" style="color: #777; text-decoration: none;">Shop</a> / 
          <a href="{{ collection.url }}" style="color: #222; font-weight: 500; text-decoration: none;">{{ collection.title }}</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="cat_product_area section_gap" id="section-{{ section.id }}">
  <div class="container">
    <div class="custom-collection-layout">
      
      <div class="custom-sidebar-column">
        <div class="left_sidebar_area">
          <form class="filter-form">
            {%- for filter in collection.filters -%}
              <aside class="left_widgets p_filter_widgets mb-4 custom-sidebar-box">
                <div class="l_w_title custom-sidebar-title">
                  <h3>{{ filter.label }}</h3>
                </div>
                
                <div class="widgets_inner">
                  {%- case filter.type -%}
                    {%- when 'list' -%}
                      <ul class="list" style="list-style: none; padding: 0; margin: 0;">
                        {%- for filter_value in filter.values -%}
                          <li style="margin-bottom: 12px;">
                            <label class="custom-radio-container">
                              <span class="filter-text {% if filter_value.active %}active-text{% endif %}">{{ filter_value.label }}</span>
                              <input type="checkbox"
                                name="{{ filter_value.param_name }}"
                                value="{{ filter_value.value }}"
                                id="Filter-{{ filter.label | escape }}-{{ forloop.index }}"
                                {% if filter_value.active -%}checked{%- endif %}
                                onchange="this.form.submit();"
                              >
                              <span class="radio-mark"></span>
                            </label>
                          </li>
                        {%- endfor -%}
                      </ul>

                    {%- when 'price_range' -%}
                      <div class="price-filter d-flex align-items-center gap-2 mt-3">
                        <input name="{{ filter.min_value.param_name }}" type="number" placeholder="Min" min="0" max="{{ filter.range_max | money_without_currency | replace: ',', '' }}" class="form-control" style="font-size: 12px; border-radius: 0;" onchange="this.form.submit();">
                        <span style="color: #777;">-</span>
                        <input name="{{ filter.max_value.param_name }}" type="number" placeholder="Max" min="0" max="{{ filter.range_max | money_without_currency | replace: ',', '' }}" class="form-control" style="font-size: 12px; border-radius: 0;" onchange="this.form.submit();">
                      </div>
                  {%- endcase -%}
                </div>
              </aside>
            {%- endfor -%}
          </form>
        </div>
      </div>

      <div class="custom-products-column">
        <div class="product_top_bar custom-top-bar d-flex justify-content-between align-items-center mb-4">
          <div class="left_dorp d-flex gap-3">
            <form id="CollectionFiltersForm" class="d-flex align-items-center gap-2">
              <select name="sort_by" class="sorting form-control custom-sort-select" id="SortBy" onchange="document.getElementById('CollectionFiltersForm').submit();">
                {%- for option in collection.sort_options -%}
                  <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected="selected"{% endif %}>
                    {{ option.name }}
                  </option>
                {%- endfor -%}
              </select>
            </form>
          </div>
          <div class="right_dorp">
            <span style="font-size: 13px; color: #777;">Showing {{ collection.products_count }} products</span>
          </div>
        </div>
        
        <div class="latest_product_inner">
          <div class="custom-product-grid">
            {% paginate collection.products by 12 %}
              {% for product in collection.products %}
                <div class="custom-grid-item">
                  <div class="single-product custom-product-card">
                    <div class="product-img custom-img-wrapper">
                      <a href="{{ product.url }}">
                        <img class="card-img product-blend" src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" />
                      </a>
                    </div>
                    <div class="product-btm custom-card-body">
                      <a href="{{ product.url }}" class="d-block text-decoration-none">
                        <h4 class="custom-product-title">{{ product.title }}</h4>
                      </a>
                      <div class="custom-price-wrap">
                        <span class="current-price">{{ product.price | money }}</span>
                        {% if product.compare_at_price > product.price %}
                          <del class="old-price">{{ product.compare_at_price | money }}</del>
                        {% endif %}
                      </div>
                    </div>
                  </div>
                </div>
              {% else %}
                <div class="custom-grid-item" style="grid-column: 1 / -1; text-align: center; padding: 50px 0;">
                  <p>No products found in this collection.</p>
                </div>
              {% endfor %}

            {% endpaginate %}
          </div>
          
          {% if paginate.pages > 1 %}
            <div class="text-center mt-5 w-100">
              {{ paginate | default_pagination }}
            </div>
          {% endif %}
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection Page",
  "settings": []
}
{% endschema %}