<section class="new_product_area section_gap_top section_gap_bottom_custom" id="section-{{ section.id }}">
  <div class="container">
    
    <div class="row justify-content-center" style="display: flex; justify-content: center; width: 100%;">
      <div class="col-lg-12" style="text-align: center;">
        <div class="main_title">
          <h2><span>{{ section.settings.title }}</span></h2>
          {% if section.settings.subtitle != blank %}
            <p>{{ section.settings.subtitle }}</p>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="new-product-row">
      
      <div class="left-column">
        <div class="new_product">
          {%- assign hero_product = all_products[section.settings.hero_product] -%}
          
          {% if hero_product != blank %}
            <h5 class="text-uppercase">{{ section.settings.hero_subtitle }}</h5>
            <h3 class="text-uppercase">{{ hero_product.title }}</h3>
            <div class="product-img">
              <a href="{{ hero_product.url }}">
                <img class="img-fluid" src="{{ hero_product.featured_image | image_url: width: 800 }}" alt="{{ hero_product.title | escape }}" />
              </a>
            </div>
            <h4>{{ hero_product.price | money }}</h4>
            
            <form action="/cart/add" method="post" enctype="multipart/form-data">
              <input type="hidden" name="id" value="{{ hero_product.variants.first.id }}">
              <button type="submit" class="main_btn">Add to cart</button>
            </form>
            
          {% else %}
            <h5 class="text-uppercase">collection of 2026</h5>
            <h3 class="text-uppercase">Men’s summer t-shirt</h3>
            <div class="product-img" style="background: #f1f2f4; padding: 50px;">
              {{ 'product-1' | placeholder_svg_tag: 'img-fluid' }}
            </div>
            <h4>{{ 12070 | money }}</h4>
            <a href="#" class="main_btn">Add to cart</a>
          {% endif %}
        </div>
      </div>

      <div class="right-column">
        <div class="right-product-grid">
          
          {%- assign collection = collections[section.settings.right_collection] -%}
          
          {% if collection != blank and collection.products_count > 0 %}
            {% for product in collection.products limit: 4 %}
              <div class="right-product-col">
                <div class="single-product">
                  <div class="product-img">
                    <img class="img-fluid w-100" src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" />
                    <div class="p_icon">
                      <a href="{{ product.url }}"><i class="ti-eye"></i></a>
                      <a href="#"><i class="ti-heart"></i></a>
                      <a href="{{ product.url }}"><i class="ti-shopping-cart"></i></a>
                    </div>
                  </div>
                  <div class="product-btm">
                    <a href="{{ product.url }}" class="d-block">
                      <h4>{{ product.title }}</h4>
                    </a>
                    <div class="mt-3">
                      <span class="mr-4">{{ product.price | money }}</span>
                      {% if product.compare_at_price > product.price %}
                        <del>{{ product.compare_at_price | money }}</del>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
            
          {% else %}
            {% for i in (1..4) %}
              <div class="right-product-col">
                <div class="single-product">
                  <div class="product-img" style="background: #f1f2f4;">
                    {{ 'product-' | append: i | placeholder_svg_tag: 'img-fluid w-100' }}
                    <div class="p_icon">
                      <a href="#"><i class="ti-eye"></i></a>
                      <a href="#"><i class="ti-heart"></i></a>
                      <a href="#"><i class="ti-shopping-cart"></i></a>
                    </div>
                  </div>
                  <div class="product-btm">
                    <a href="#" class="d-block">
                      <h4>Sample Product</h4>
                    </a>
                    <div class="mt-3">
                      <span class="mr-4">{{ 2500 | money }}</span>
                      <del>{{ 3500 | money }}</del>
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
          {% endif %}
          
        </div>
      </div>
      
    </div>
  </div>
</section>
{% schema %}
{
  "name": "New Products Layout",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "New Products"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sub Heading",
      "default": "Bring called seed first of third give itself now ment"
    },
    {
      "type": "header",
      "content": "Left Side (Hero Product)"
    },
    {
      "type": "text",
      "id": "hero_subtitle",
      "label": "Hero Subtitle",
      "default": "Collection of 2026"
    },
    {
      "type": "product",
      "id": "hero_product",
      "label": "Select Hero Product"
    },
    {
      "type": "header",
      "content": "Right Side (Product Grid)"
    },
    {
      "type": "collection",
      "id": "right_collection",
      "label": "Select Collection",
      "info": "This will display the first 4 products of the chosen collection."
    }
  ],
  "presets": [
    {
      "name": "New Products Split Layout"
    }
  ]
}
{% endschema %}