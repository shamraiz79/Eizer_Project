<section class="custom-banner-area" style="background-color: {{ section.settings.banner_bg_color }};">
  <div class="custom-container">
    <div class="banner-content-wrap">
      <div class="banner-text">
        <h2>{{ section.settings.banner_title | escape }}</h2>
        <p>{{ section.settings.banner_subtitle | escape }}</p>
      </div>
      <div class="banner-breadcrumbs">
        <a href="{{ routes.root_url }}">Home</a> / 
        <span>{{ section.settings.banner_title | escape }}</span>
      </div>
    </div>
  </div>
</section>

<div class="single-product-area" id="section-{{ section.id }}">
  <div class="custom-container">
    <div class="product-grid-layout">
      
      <div class="product-gallery-col">
        <div class="s_product_img_wrap">
          <img id="MainProductImage" src="{{ product.featured_media | image_url: width: 800 }}" alt="{{ product.title | escape }}" />
          
          <div class="thumbnail-container">
            {% for media in product.media %}
              <img class="product-thumbnail {% if forloop.first %}active{% endif %}" src="{{ media | image_url: width: 150 }}" alt="{{ media.alt | escape }}" data-main-src="{{ media | image_url: width: 800 }}" onclick="changeMainImage(this)" />
            {% endfor %}
          </div>
        </div>
      </div>
      
      <div class="product-details-col">
        <div class="s_product_text">
          <h3>{{ product.title }}</h3>
          
          <!-- Added ID to price so JS can update it -->
          <h2 id="ProductPrice">{{ product.selected_or_first_available_variant.price | money }}</h2>
          
          <ul class="product-meta-list">
            {% if section.settings.show_category %}
              <li><a href="#"><span>Category</span> : <span class="text-green">{{ product.type | default: 'Household' }}</span></a></li>
            {% endif %}
            {% if section.settings.show_availability %}
              <li><a href="#"><span>Availability</span> : <span id="ProductAvailability">{% if product.selected_or_first_available_variant.available %}In Stock{% else %}Out of Stock{% endif %}</span></a></li>
            {% endif %}
          </ul>
          
          <p class="product-short-desc">{{ product.description | strip_html | truncatewords: 40 }}</p>
          
          {% form 'product', product, class: 'custom-product-form' %}
            
            <!-- Hidden input that JS will update -->
            <input type="hidden" name="id" id="ProductVariantId" value="{{ product.selected_or_first_available_variant.id }}">
            
            <!-- ===== NEW VARIANT SELECTORS ===== -->
            {% unless product.has_only_default_variant %}
              <div class="product-variant-selectors" style="margin: 20px 0; display: flex; gap: 15px; flex-wrap: wrap;">
                {% for option in product.options_with_values %}
                  <div class="selector-wrapper" style="flex: 1; min-width: 120px;">
                    <label for="SingleOptionSelector-{{ forloop.index0 }}" style="display: block; font-size: 14px; font-weight: 500; color: #222; margin-bottom: 5px;">
                      {{ option.name }}
                    </label>
                    <select class="single-option-selector" data-index="option{{ forloop.index }}" id="SingleOptionSelector-{{ forloop.index0 }}" style="width: 100%; padding: 10px; border: 1px solid #e0e0e0; border-radius: 4px; background: #fff; outline: none; cursor: pointer;">
                      {% for value in option.values %}
                        <option value="{{ value | escape }}" {% if option.selected_value == value %}selected="selected"{% endif %}>
                          {{ value }}
                        </option>
                      {% endfor %}
                    </select>
                  </div>
                {% endfor %}
              </div>
            {% endunless %}
            <!-- ================================== -->

            <div class="product-qty-wrap" style="margin-top: 10px;">
              <label for="sst">Quantity:</label>
              <input type="number" name="quantity" id="sst" min="1" value="1" title="Quantity:" class="custom-qty-input" />
            </div>
            
            <div class="product-action-wrap">
              <button type="submit" name="add" id="AddToCartBtn" class="main-btn {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
                <span id="AddToCartText">
                  {% if product.selected_or_first_available_variant.available %}Add to Cart{% else %}Sold Out{% endif %}
                </span>
              </button>
              <a class="icon-btn" href="#"><i class="ti-gem"></i></a>
              <a class="icon-btn" href="#"><i class="ti-heart"></i></a>
            </div>
          {% endform %}
          
        </div>
      </div>
    </div>
  </div>
</div> 

<!-- Store the product data for JavaScript -->
<script type="application/json" id="ProductJson-{{ section.id }}">
  {{ product.variants | json }}
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Grab the elements
  var productVariants = JSON.parse(document.getElementById('ProductJson-{{ section.id }}').innerHTML);
  var selectors = document.querySelectorAll('.single-option-selector');
  var variantInput = document.getElementById('ProductVariantId');
  var priceElement = document.getElementById('ProductPrice');
  var addToCartBtn = document.getElementById('AddToCartBtn');
  var addToCartText = document.getElementById('AddToCartText');
  var availabilityText = document.getElementById('ProductAvailability');
  
  // NEW: Grab the Main Image element
  var mainImage = document.getElementById('MainProductImage');

  // Basic money formatter 
  function formatMoney(cents) {
    var amount = (cents / 100).toFixed(2);
    // You can change 'Rs.' below to match your exact currency symbol formatting
    return 'Rs.' + amount; 
  }

  // Listen for changes on any dropdown
  selectors.forEach(function(selector) {
    selector.addEventListener('change', function() {
      
      // 1. Get the currently selected values from all dropdowns
      var selectedOptions = [];
      selectors.forEach(function(sel) {
        selectedOptions.push(sel.value);
      });

      // 2. Find the exact variant that matches these selected options
      var matchedVariant = productVariants.find(function(variant) {
        var match1 = selectedOptions[0] ? variant.option1 === selectedOptions[0] : true;
        var match2 = selectedOptions[1] ? variant.option2 === selectedOptions[1] : true;
        var match3 = selectedOptions[2] ? variant.option3 === selectedOptions[2] : true;
        return match1 && match2 && match3;
      });

      // 3. Update the page based on the matched variant
      if (matchedVariant) {
        // Update the hidden input that goes to the cart
        variantInput.value = matchedVariant.id;
        
        // Update the price
        priceElement.innerHTML = formatMoney(matchedVariant.price);

        // NEW: Update the Image if the variant has one assigned
        if (matchedVariant.featured_image && mainImage) {
          mainImage.src = matchedVariant.featured_image.src;
        }

        // Update Button & Availability text
        if (matchedVariant.available) {
          addToCartBtn.classList.remove('disabled');
          addToCartBtn.disabled = false;
          addToCartText.innerHTML = 'Add to Cart';
          if(availabilityText) availabilityText.innerHTML = 'In Stock';
        } else {
          addToCartBtn.classList.add('disabled');
          addToCartBtn.disabled = true;
          addToCartText.innerHTML = 'Sold Out';
          if(availabilityText) availabilityText.innerHTML = 'Out of Stock';
        }
      } else {
        // Fallback if that specific combination doesn't exist
        addToCartBtn.classList.add('disabled');
        addToCartBtn.disabled = true;
        addToCartText.innerHTML = 'Unavailable';
        if(availabilityText) availabilityText.innerHTML = 'Unavailable';
      }
    });
  });
});
</script>

<section class="product-tabs-area">
  <div class="custom-container">
    
    <ul class="custom-nav-tabs" id="myTab">
      <li><a class="tab-link active" data-target="description">Description</a></li>
      
      {% if section.settings.show_specs_tab %}
        <li><a class="tab-link" data-target="specification">Specification</a></li>
      {% endif %}
      
      {% if section.settings.show_comments_tab %}
        <li><a class="tab-link" data-target="comments">Comments</a></li>
      {% endif %}
      
      {% if section.settings.show_reviews_tab %}
        <li><a class="tab-link" data-target="reviews">Reviews</a></li>
      {% endif %}
    </ul>
    
    <div class="custom-tab-content">
      
      <div class="tab-pane active" id="description">
        {{ product.description }}
      </div>
      
  {% if section.settings.show_specs_tab %}
  <div class="tab-pane" id="specification">
    <table class="custom-spec-table">
      <tbody>

        {% if product.metafields.custom.width != blank %}
        <tr>
          <td><h5>Width</h5></td>
          <td>
            <p>
              {{ product.metafields.custom.width.value }} {{ product.metafields.custom.width.unit }}
            </p>
          </td>
        </tr>
        {% endif %}

        {% if product.metafields.custom.height != blank %}
        <tr>
          <td><h5>Height</h5></td>
          <td>
            <p>
              {{ product.metafields.custom.height.value }} {{ product.metafields.custom.height.unit }}
            </p>
          </td>
        </tr>
        {% endif %}

        {% if product.metafields.custom.depth != blank %}
        <tr>
          <td><h5>Depth</h5></td>
          <td>
            <p>
              {{ product.metafields.custom.depth.value }} {{ product.metafields.custom.depth.unit }}
            </p>
          </td>
        </tr>
        {% endif %}

        {% if product.metafields.custom.quality_checking != blank %}
        <tr>
          <td><h5>Quality checking</h5></td>
          <td><p>{{ product.metafields.custom.quality_checking }}</p></td>
        </tr>
        {% endif %}

        {% if product.metafields.custom.when_packeting != blank %}
        <tr>
          <td><h5>When packeting</h5></td>
          <td><p>{{ product.metafields.custom.when_packeting }}</p></td>
        </tr>
        {% endif %}

        {% if product.metafields.custom.each_box_contains != blank %}
        <tr>
          <td><h5>Each Box contains</h5></td>
          <td><p>{{ product.metafields.custom.each_box_contains }}</p></td>
        </tr>
        {% endif %}

      </tbody>
    </table>
  </div>
{% endif %}
      
   {% if section.settings.show_comments_tab %}
<div class="tab-pane" id="comments">
  <div class="comments-layout-wrap" style="display: flex; gap: 30px;">
    
    <div class="comments-list-section" style="flex: 1;">
      
      {% if product.metafields.custom.coments %}
        {% for comment in product.metafields.custom.coments.value %}
          <div class="single-comment" style="display: flex; gap: 15px; margin-bottom: 30px;">
            
           <div class="comment-avatar">
  {% if comment.image %}
    <img src="{{ comment.image.value | image_url: width: 100 }}" alt="{{ comment.author_name.value }}" style="width: 60px; height: 60px; border-radius: 50%; object-fit: cover;">
  {% else %}
    <div class="placeholder-avatar" style="width: 60px; height: 60px; background: #eee; border-radius: 50%;"></div>
  {% endif %}
</div>

            <div class="comment-content">
              <div class="comment-header" style="display: flex; justify-content: space-between;">
                <div>
                  <h5 style="margin: 0; font-size: 16px;">{{ comment.author_name.value }}</h5>
                  <p style="margin: 0; font-size: 12px; color: #888;">{{ comment.date.value | date: "%dth %b, %Y" }}</p>
                </div>
                <button class="reply-btn" style="border: 1px solid #ddd; background: transparent; padding: 5px 15px; border-radius: 20px;">Reply</button>
              </div>
              <p style="margin-top: 15px; color: #666; font-size: 14px; line-height: 1.6;">{{ comment.message.value }}</p>
            </div>
          </div>
        {% endfor %}
      {% else %}
        <p>No comments yet. Be the first to leave one!</p>
      {% endif %}
    </div>

    <div class="comment-form-section" style="flex: 1;">
      <h3 style="margin-bottom: 20px;">Post a comment</h3>
      {% form 'contact' %}
        <input type="text" name="contact[name]" placeholder="Your Full Name" style="width: 100%; margin-bottom: 15px; padding: 10px; border: 1px solid #eee;">
        <input type="email" name="contact[email]" placeholder="Email Address" style="width: 100%; margin-bottom: 15px; padding: 10px; border: 1px solid #eee;">
        <input type="tel" name="contact[phone]" placeholder="Phone Number" style="width: 100%; margin-bottom: 15px; padding: 10px; border: 1px solid #eee;">
        <textarea name="contact[body]" placeholder="Message" rows="4" style="width: 100%; margin-bottom: 15px; padding: 10px; border: 1px solid #eee;"></textarea>
        <button type="submit" style="background: #71cd14; color: white; border: none; padding: 12px 30px; cursor: pointer; float: right; font-weight: 500;">Submit Now</button>
      {% endform %}
    </div>
    
  </div>
</div>
{% endif %}
      
      {% if section.settings.show_reviews_tab %}
      <div class="tab-pane" id="reviews"><p class="placeholder-text">Reviews section.</p></div>
      {% endif %}
      
    </div>
  </div>
</section>

<script>
  function changeMainImage(element) {
    document.getElementById('MainProductImage').src = element.getAttribute('data-main-src');
    document.querySelectorAll('.product-thumbnail').forEach(thumb => thumb.classList.remove('active'));
    element.classList.add('active');
  }

  document.addEventListener('DOMContentLoaded', function() {
    const tabLinks = document.querySelectorAll('.tab-link');
    const tabPanes = document.querySelectorAll('.tab-pane');

    tabLinks.forEach(link => {
      link.addEventListener('click', function() {
        tabLinks.forEach(l => l.classList.remove('active'));
        tabPanes.forEach(p => p.classList.remove('active'));
        
        this.classList.add('active');
        document.getElementById(this.getAttribute('data-target')).classList.add('active');
      });
    });
  });
</script>


{% if section.settings.cart_type == 'drawer' %}
<script>
document.addEventListener('DOMContentLoaded', function() {
  const productForm = document.querySelector('.custom-product-form');
  const addToCartBtn = document.getElementById('AddToCartBtn');
  const addToCartText = document.getElementById('AddToCartText');

  // Find Drawer Elements globally
  const drawer = document.getElementById('CartDrawer');
  const overlay = document.getElementById('CartDrawerOverlay');
  const closeBtn = document.getElementById('CartDrawerClose');
  const drawerBody = document.getElementById('CartDrawerBody');
  const drawerTotal = document.getElementById('CartDrawerTotal');

  // 1. ADD TO CART INTERCEPT
  if (productForm) {
    productForm.addEventListener('submit', function(e) {
      e.preventDefault();
      
      addToCartText.innerHTML = 'Adding...';
      addToCartBtn.disabled = true;

      const formData = new FormData(productForm);

      fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        body: formData
      })
      .then(response => response.json())
      .then(data => {
        if (data.status) {
          alert('Error: ' + data.description);
          resetMainButton();
          return;
        }
        resetMainButton();
        updateAndOpenDrawer(); // Success! Open Drawer
      })
      .catch(error => {
        console.error('Error:', error);
        resetMainButton();
      });
    });
  }

  function resetMainButton() {
    addToCartText.innerHTML = 'Add to Cart';
    addToCartBtn.disabled = false;
  }

  // 2. FETCH LATEST CART & BUILD HTML
  function updateAndOpenDrawer() {
    fetch('/cart.js')
      .then(response => response.json())
      .then(cart => {
        buildCartHTML(cart);
        openDrawer();
      });
  }

  // 3. DYNAMICALLY GENERATE CART ITEMS & PRICING
  function buildCartHTML(cart) {
    drawerTotal.innerHTML = '$' + (cart.total_price / 100).toFixed(2);

    if (cart.items.length === 0) {
      drawerBody.innerHTML = '<p class="empty-cart-msg">Your cart is currently empty.</p>';
      return;
    }

    let html = '';
    cart.items.forEach(item => {
      html += `
        <div class="drawer-item">
          <img src="${item.image}" alt="${item.title}" class="drawer-item-img">
          <div class="drawer-item-details">
            <a href="${item.url}" class="drawer-item-title">${item.product_title}</a>
            <p class="drawer-item-price">$${(item.price / 100).toFixed(2)}</p>
            <div class="drawer-qty-wrap">
              <button type="button" class="drawer-qty-btn minus" data-key="${item.key}" data-qty="${item.quantity - 1}">-</button>
              <input type="text" class="drawer-qty-input" value="${item.quantity}" readonly>
              <button type="button" class="drawer-qty-btn plus" data-key="${item.key}" data-qty="${item.quantity + 1}">+</button>
            </div>
          </div>
        </div>
      `;
    });
    drawerBody.innerHTML = html;
  }

  // 4. HANDLE DRAWER ANIMATIONS
  function openDrawer() {
    drawer.classList.add('is-active');
    overlay.classList.add('is-active');
    document.body.style.overflow = 'hidden'; 
  }

  function closeDrawer() {
    drawer.classList.remove('is-active');
    overlay.classList.remove('is-active');
    document.body.style.overflow = '';
  }

  if(closeBtn) closeBtn.addEventListener('click', closeDrawer);
  if(overlay) overlay.addEventListener('click', closeDrawer);

  // 5. HANDLE QUANTITY UPDATES (+ / - BUTTONS)
  if (drawerBody) {
    drawerBody.addEventListener('click', function(e) {
      if (e.target.classList.contains('drawer-qty-btn')) {
        const key = e.target.getAttribute('data-key');
        const newQty = e.target.getAttribute('data-qty');
        
        drawerBody.style.opacity = '0.4'; 

        fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: key, quantity: newQty })
        })
        .then(response => response.json())
        .then(cart => {
          drawerBody.style.opacity = '1';
          buildCartHTML(cart); 
        });
      }
    });
  }
});
</script>
{% endif %}

{% schema %}
{
  "name": "Product Details",
  "settings": [
    {
      "type": "header",
      "content": "Banner Settings"
    },
    {
      "type": "text",
      "id": "banner_title",
      "label": "Banner Title",
      "default": "Product Details"
    },
    {
      "type": "text",
      "id": "banner_subtitle",
      "label": "Banner Subtitle",
      "default": "Very us move be blessed multiply night"
    },
    {
      "type": "color",
      "id": "banner_bg_color",
      "label": "Banner Background",
      "default": "#f9f9fa"
    },
    {
      "type": "header",
      "content": "Product Information"
    },
    {
      "type": "checkbox",
      "id": "show_category",
      "label": "Show Category",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_availability",
      "label": "Show Availability",
      "default": true
    },
    {
      "type": "header",
      "content": "Cart Behavior"
    },
    {
      "type": "select",
      "id": "cart_type",
      "label": "After adding to cart, open:",
      "options": [
        {
          "value": "drawer",
          "label": "Slide-out Cart Drawer"
        },
        {
          "value": "page",
          "label": "Full Cart Page"
        }
      ],
      "default": "page"
    },
    {
      "type": "header",
      "content": "Tabs Settings"
    },
    {
      "type": "checkbox",
      "id": "show_specs_tab",
      "label": "Show Specification Tab",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_comments_tab",
      "label": "Show Comments Tab",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_reviews_tab",
      "label": "Show Reviews Tab",
      "default": true
    }
  ]
}
{% endschema %}