<section class="feature-area section_gap_bottom_custom" id="section-{{ section.id }}">
  <div class="container">
    <div class="row">
      
      {% for block in section.blocks %}
        <div class="col-lg-3 col-md-6 feature-column" {{ block.shopify_attributes }}>
          <div class="single-feature">
            <a href="{{ block.settings.link | default: '#' }}" class="title">
              
              {% if block.settings.icon_image != blank %}
                <img src="{{ block.settings.icon_image | image_url: width: 60 }}" alt="{{ block.settings.title }}" style="width: 45px; height: auto; margin-bottom: 15px;">
              {% elsif block.settings.icon_class != blank %}
                <i class="{{ block.settings.icon_class }}"></i>
              {% endif %}
              
              <h3>{{ block.settings.title }}</h3>
            </a>
            <p>{{ block.settings.text }}</p>
          </div>
        </div>
      {% endfor %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Store Features",
  "max_blocks": 4,
  "settings": [],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Upload Icon Image (Recommended)",
          "info": "Upload a PNG or SVG icon."
        },
        {
          "type": "text",
          "id": "icon_class",
          "label": "Icon Class (Fallback)",
          "default": "flaticon-money",
          "info": "Only used if no image is uploaded."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Money back guarantee"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Shall open divide a one"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store Features",
      "blocks": [
        { "type": "feature", "settings": { "title": "Money back guarantee" } },
        { "type": "feature", "settings": { "title": "Free Delivery" } },
        { "type": "feature", "settings": { "title": "Always support" } },
        { "type": "feature", "settings": { "title": "Secure payment" } }
      ]
    }
  ]
}
{% endschema %}