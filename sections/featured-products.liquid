  .modal-details {
    flex: 1 1 calc(50% - 15px);
    min-width: 300px;
  }

  /* 7. Gallery Main Image (FIXED DYNAMIC SELECTOR) */
  .modal-gallery img[id^="MainProductImage-"] {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-bottom: 15px;
    display: block;
    position: relative;
  }

  /* 8. Thumbnail Container */
  .modal-gallery .thumbnail-container {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    width: 100%;
    position: relative;
    z-index: 1;
    justify-content: flex-start; /* Aligns thumbnails to the left under the image */
  }

  /* 9. Thumbnail Image styling */
  .modal-gallery img[class*="modal-thumbnail-"] {
    width: 60px;
    height: 60px;
