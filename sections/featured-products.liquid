<section class="feature_product_area section_gap_bottom_custom" id="section-{{ section.id }}">
  <div class="container">
    
    <div class="row justify-content-center" style="display: flex; justify-content: center; width: 100%;">
      <div class="col-lg-12" style="text-align: center;">
        <div class="main_title">
          <h2><span>{{ section.settings.title }}</span></h2>
          {% if section.settings.subtitle != blank %}
            <p>{{ section.settings.subtitle }}</p>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="row">
      {%- assign collection = collections[section.settings.feature_collection] -%}
      
      {% if collection != blank and collection.products_count > 0 %}
        {% for product in collection.products limit: section.settings.product_limit %}
          <div class="col-lg-4 col-md-6 feature-col">
            <div class="single-product">
              <div class="product-img">
                <img class="img-fluid w-100" src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" />
                <div class="p_icon">
                  <a href="#" class="quick-view-trigger" data-id="{{ product.id }}"><i class="ti-eye"></i></a>
                  <a href="#"><i class="ti-heart"></i></a>
                  <a href="#" class="ajax-cart-icon-trigger" data-variant-id="{{ product.selected_or_first_available_variant.id }}">
                    <i class="ti-shopping-cart"></i>
                  </a>
                </div>
              </div>
              <div class="product-btm">
                <a href="{{ product.url }}" class="d-block">
                  <h4>{{ product.title }}</h4>
                </a>
                <div class="mt-3">
                  <span class="mr-4">{{ product.price | money }}</span>
                  {% if product.compare_at_price > product.price %}
                    <del>{{ product.compare_at_price | money }}</del>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>

          <div id="QuickViewModal-{{ product.id }}" class="custom-quick-view-modal" data-product-id="{{ product.id }}">
            <div class="modal-content-wrap">
              <span class="close-modal" data-id="{{ product.id }}">&times;</span>
              
              <div class="modal-grid">
                <div class="modal-gallery">
                  <img id="MainProductImage-{{ product.id }}" src="{{ product.featured_media | image_url: width: 800 }}" alt="{{ product.title | escape }}" style="width: 100%; border-radius: 8px; margin-bottom: 10px;" />
                  
                  <div class="thumbnail-container" style="display: flex; gap: 5px; flex-wrap: wrap;">
                    {% for media in product.media %}
                      <img class="modal-thumbnail-{{ product.id }} {% if forloop.first %}active{% endif %}" 
                           src="{{ media | image_url: width: 150 }}" 
                           alt="{{ media.alt | escape }}" 
                           data-main-src="{{ media | image_url: width: 800 }}" 
                           data-color="{{ media.alt | downcase | escape }}" 
                           style="width: 60px; height: 60px; object-fit: cover; cursor: pointer; border: 1px solid #ddd; border-radius: 4px;" />
                    {% endfor %}
                  </div>
                </div>

                <div class="modal-details">
                  <h3>{{ product.title }}</h3>
                  <h2 id="ProductPrice-{{ product.id }}" style="color: #82b53f; margin: 10px 0;">{{ product.selected_or_first_available_variant.price | money }}</h2>
                  
                  <p style="font-size: 14px; color: #777;">{{ product.description | strip_html | truncatewords: 25 }}</p>
                  
                  <div class="modal-form-wrap" style="margin-top: 20px;">
                    <input type="hidden" id="ProductVariantId-{{ product.id }}" value="{{ product.selected_or_first_available_variant.id }}">
                    
                    {% unless product.has_only_default_variant %}
                      <div style="margin-bottom: 15px;">
                        {% for option in product.options_with_values %}
                          <div style="margin-bottom: 10px;">
                            <label style="display: block; font-size: 13px; font-weight: bold; margin-bottom: 5px;">{{ option.name }}</label>
                            <select class="single-option-selector-{{ product.id }}" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px;">
                              {% for value in option.values %}
                                <option value="{{ value | escape }}" {% if option.selected_value == value %}selected="selected"{% endif %}>{{ value }}</option>
                              {% endfor %}
                            </select>
                          </div>
                        {% endfor %}
                      </div>
                    {% endunless %}

                    <div style="display: flex; gap: 10px; align-items: center;">
                      <input type="number" id="Quantity-{{ product.id }}" value="1" min="1" style="width: 60px; padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
                      <button type="button" class="modal-add-to-cart main-btn" data-id="{{ product.id }}" style="flex: 1; padding: 10px; background: #82b53f; color: #fff; border: none; border-radius: 4px; cursor: pointer;">
                        <span id="AddToCartText-{{ product.id }}">{% if product.selected_or_first_available_variant.available %}Add to Cart{% else %}Sold Out{% endif %}</span>
                      </button>
                    </div>
                  </div>

                  <script type="application/json" id="ProductJson-{{ product.id }}">{{ product.variants | json }}</script>
                  <script type="application/json" id="ProductOptionsJson-{{ product.id }}">{{ product.options | json }}</script>

                </div>
              </div>
            </div>
          </div>
          {% endfor %}
      {% else %}
        <p>No products found in this collection.</p>
      {% endif %}
    </div>
  </div>
</section>

<style>
  /* 1. Prevent Conflict with Theme CSS (CRITICAL FIX) */
  .custom-quick-view-modal [class*="modal-thumbnail-"] {
    position: static !important; /* Stops absolute positioning overlap */
    display: inline-block !important; /* Keeps them in a row */
    float: none !important; /* Stops them from floating over text */
    transform: none !important;
    margin: 0 !important;
  }

  /* 2. Main Modal Container */
  .custom-quick-view-modal {
    display: none;
    position: fixed;
    z-index: 99999; /* Ensure it stays on top of everything */
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0,0,0,0.7);
    align-items: center;
    justify-content: center;
  }

  /* 3. The Modal Content Box */
  .modal-content-wrap {
    background-color: #fff;
    padding: 30px;
    border-radius: 10px;
    width: 90%;
    max-width: 800px;
    position: relative;
    max-height: 90vh;
    overflow-y: auto;
  }

  /* 4. The Close Button (X) */
  .close-modal {
    position: absolute;
    top: 10px;
    right: 15px;
    font-size: 28px;
    font-weight: bold;
    color: #333;
    cursor: pointer;
    z-index: 2;
  }

  /* 5. Main Content Grid (Flexbox) */
  .modal-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 30px;
    width: 100%;
  }

  /* 6. Columns */
  .modal-gallery,
  .modal-details {
    flex: 1 1 calc(50% - 15px);
    min-width: 300px;
  }

  /* 7. Gallery Main Image (FIXED DYNAMIC SELECTOR) */
  .modal-gallery img[id^="MainProductImage-"] {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-bottom: 15px;
    display: block;
    position: relative;
  }

  /* 8. Thumbnail Container */
  .modal-gallery .thumbnail-container {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    width: 100%;
    position: relative;
    z-index: 1;
    justify-content: flex-start; /* Aligns thumbnails to the left under the image */
  }

  /* 9. Thumbnail Image styling */
  .modal-gallery img[class*="modal-thumbnail-"] {
    width: 60px;
    height: 60px;
    object-fit: cover;
    cursor: pointer;
    border: 1px solid #ddd;
    border-radius: 4px;
    padding: 2px;
  }

  /* 10. Active Thumbnail styling */
  img[class*="modal-thumbnail-"].active {
    border-color: #82b53f !important;
    border-width: 2px;
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  
  // 1. AJAX CART LOGIC (From your original code)
  const cartIcons = document.querySelectorAll('.ajax-cart-icon-trigger');
  cartIcons.forEach(icon => {
    icon.addEventListener('click', function(e) {
      e.preventDefault(); 
      const variantId = this.getAttribute('data-variant-id');
      if (!variantId) return;

      this.style.opacity = '0.5';
      this.style.pointerEvents = 'none';

      fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 'items': [{ 'id': variantId, 'quantity': 1 }] })
      })
      .then(response => response.json())
      .then(data => {
        this.style.opacity = '1';
        this.style.pointerEvents = 'auto';
        const headerCartIcon = document.getElementById('openCartDrawer');
        if (headerCartIcon) headerCartIcon.click();
      })
      .catch((error) => {
        console.error('Error:', error);
        this.style.opacity = '1';
        this.style.pointerEvents = 'auto';
      });
    });
  });

  // 2. MODAL OPEN/CLOSE LOGIC
  const triggers = document.querySelectorAll('.quick-view-trigger');
  const closeBtns = document.querySelectorAll('.close-modal');

  triggers.forEach(trigger => {
    trigger.addEventListener('click', function(e) {
      e.preventDefault();
      const pid = this.getAttribute('data-id');
      document.getElementById('QuickViewModal-' + pid).style.display = 'flex';
    });
  });

  closeBtns.forEach(btn => {
    btn.addEventListener('click', function() {
      const pid = this.getAttribute('data-id');
      document.getElementById('QuickViewModal-' + pid).style.display = 'none';
    });
  });

  // Close when clicking outside the modal box
  window.addEventListener('click', function(e) {
    if (e.target.classList.contains('custom-quick-view-modal')) {
      e.target.style.display = 'none';
    }
  });

  // 3. VARIANT & IMAGE FILTERING LOGIC (Scoped per modal)
  const modals = document.querySelectorAll('.custom-quick-view-modal');
  
  modals.forEach(modal => {
    const pid = modal.getAttribute('data-product-id');
    
    // Safety check in case product has no variants
    const jsonEl = document.getElementById('ProductJson-' + pid);
    if(!jsonEl) return; 

    const productVariants = JSON.parse(jsonEl.innerHTML);
    const productOptions = JSON.parse(document.getElementById('ProductOptionsJson-' + pid).innerHTML);
    
    const selectors = modal.querySelectorAll('.single-option-selector-' + pid);
    const variantInput = document.getElementById('ProductVariantId-' + pid);
    const priceElement = document.getElementById('ProductPrice-' + pid);
    const addToCartBtn = modal.querySelector('.modal-add-to-cart');
    const addToCartText = document.getElementById('AddToCartText-' + pid);
    const mainImage = document.getElementById('MainProductImage-' + pid);
    const thumbnails = modal.querySelectorAll('.modal-thumbnail-' + pid);

    // Thumbnail Click Logic
    thumbnails.forEach(thumb => {
      thumb.addEventListener('click', function() {
        mainImage.src = this.getAttribute('data-main-src');
        thumbnails.forEach(t => t.classList.remove('active'));
        this.classList.add('active');
      });
    });

    // Add to Cart Button Logic inside Modal
    addToCartBtn.addEventListener('click', function(e) {
      e.preventDefault();
      const qty = document.getElementById('Quantity-' + pid).value;
      const vid = variantInput.value;
      
      addToCartBtn.style.opacity = '0.5';
      
      fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 'items': [{ 'id': vid, 'quantity': parseInt(qty) }] })
      })
      .then(res => res.json())
      .then(() => {
        addToCartBtn.style.opacity = '1';
        modal.style.display = 'none'; // Close modal on success
        const headerCartIcon = document.getElementById('openCartDrawer');
        if (headerCartIcon) headerCartIcon.click();
      });
    });

    // Color/Variant Change Logic
    let colorOptionIndex = productOptions.findIndex(opt => opt.toLowerCase() === 'color' || opt.toLowerCase() === 'colour');

    function formatMoney(cents) {
      return 'Rs.' + (cents / 100).toFixed(2); 
    }

    selectors.forEach(selector => {
      selector.addEventListener('change', function() {
        let selectedOptions = Array.from(selectors).map(s => s.value);

        let matchedVariant = productVariants.find(v => {
          return (selectedOptions[0] ? v.option1 === selectedOptions[0] : true) &&
                 (selectedOptions[1] ? v.option2 === selectedOptions[1] : true) &&
                 (selectedOptions[2] ? v.option3 === selectedOptions[2] : true);
        });

        if (matchedVariant) {
          variantInput.value = matchedVariant.id;
          priceElement.innerHTML = formatMoney(matchedVariant.price);

          // Image Filtering
          if (colorOptionIndex !== -1) {
            let activeColor = matchedVariant['option' + (colorOptionIndex + 1)].toLowerCase();
            
            thumbnails.forEach(thumb => {
              let thumbColor = thumb.getAttribute('data-color');
              if (!thumbColor || thumbColor === activeColor) {
                thumb.style.display = 'inline-block';
              } else {
                thumb.style.display = 'none';
              }
            });

            // Set main image to first visible thumbnail
            let firstVisible = Array.from(thumbnails).find(t => t.style.display !== 'none');
            if (firstVisible && mainImage) {
              mainImage.src = firstVisible.getAttribute('data-main-src');
              thumbnails.forEach(t => t.classList.remove('active'));
              firstVisible.classList.add('active');
            }
          } else if (matchedVariant.featured_image && mainImage) {
             mainImage.src = matchedVariant.featured_image.src;
          }

          // Button State
          if (matchedVariant.available) {
            addToCartBtn.classList.remove('disabled');
            addToCartBtn.disabled = false;
            addToCartText.innerHTML = 'Add to Cart';
          } else {
            addToCartBtn.classList.add('disabled');
            addToCartBtn.disabled = true;
            addToCartText.innerHTML = 'Sold Out';
          }
        }
      });
    });
  });
});
</script>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Featured product"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sub Heading",
      "default": "Bring called seed first of third give itself now ment"
    },
    {
      "type": "collection",
      "id": "feature_collection",
      "label": "Select Collection to Display"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 3,
      "max": 12,
      "step": 3,
      "label": "Number of products to show",
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Featured Products",
      "category": "Products"
    }
  ]
}
{% endschema %}