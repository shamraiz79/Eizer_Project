<section class="feature_product_area section_gap_bottom_custom" id="section-{{ section.id }}">
  <div class="container">
    
    <div class="row justify-content-center" style="display: flex; justify-content: center; width: 100%;">
      <div class="col-lg-12" style="text-align: center;">
        <div class="main_title">
          <h2><span>{{ section.settings.title }}</span></h2>
          {% if section.settings.subtitle != blank %}
            <p>{{ section.settings.subtitle }}</p>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="row">
      {%- assign collection = collections[section.settings.feature_collection] -%}
      
      {% if collection != blank and collection.products_count > 0 %}
        {% for product in collection.products limit: section.settings.product_limit %}
          <div class="col-lg-4 col-md-6 feature-col">
            <div class="single-product">
              <div class="product-img">
                <img class="img-fluid w-100" src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" />
                <div class="p_icon">
                  <a href="{{ product.url }}"><i class="ti-eye"></i></a>
                  <a href="#"><i class="ti-heart"></i></a>
                 <a href="{{ product.url }}" class="ajax-cart-icon-trigger" data-variant-id="{{ product.selected_or_first_available_variant.id }}">
                 <i class="ti-shopping-cart"></i>
                 </a>
                </div>
              </div>
              <div class="product-btm">
                <a href="{{ product.url }}" class="d-block">
                  <h4>{{ product.title }}</h4>
                </a>
                <div class="mt-3">
                  <span class="mr-4">{{ product.price | money }}</span>
                  {% if product.compare_at_price > product.price %}
                    <del>{{ product.compare_at_price | money }}</del>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
        
      {% else %}
        {% for i in (1..3) %}
          <div class="col-lg-4 col-md-6 feature-col">
            <div class="single-product">
              <div class="product-img" style="background: #f1f2f4;">
                {{ 'product-' | append: i | placeholder_svg_tag: 'img-fluid w-100' }}
                <div class="p_icon">
                  <a href="#"><i class="ti-eye"></i></a>
                  <a href="#"><i class="ti-heart"></i></a>
                  <a href="#"><i class="ti-shopping-cart"></i></a>
                </div>
              </div>
              <div class="product-btm">
                <a href="#" class="d-block">
                  <h4>Sample Product Title</h4>
                </a>
                <div class="mt-3">
                  <span class="mr-4">{{ 2500 | money }}</span>
                  <del>{{ 3500 | money }}</del>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
      
    </div>
  </div>
</section>


<script>
document.addEventListener('DOMContentLoaded', function() {
  
  // Find all of your new cart icons
  const cartIcons = document.querySelectorAll('.ajax-cart-icon-trigger');

  cartIcons.forEach(icon => {
    icon.addEventListener('click', function(e) {
      
      // 1. Stop the browser from going to the product page!
      e.preventDefault(); 
      
      // 2. Get the specific product ID we added to the HTML
      const variantId = this.getAttribute('data-variant-id');
      if (!variantId) return;

      // Make the icon slightly transparent so the user knows it's working
      this.style.opacity = '0.5';
      this.style.pointerEvents = 'none';

      // 3. Send it to the cart (Using the exact same logic as your Product Page)
      fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          'items': [{
            'id': variantId,
            'quantity': 1
          }]
        })
      })
      .then(response => response.json())
      .then(data => {
        
        // Reset the icon back to normal
        this.style.opacity = '1';
        this.style.pointerEvents = 'auto';

        // 4. Open the Drawer by triggering the header icon!
        const headerCartIcon = document.getElementById('openCartDrawer');
        if (headerCartIcon) {
          headerCartIcon.click();
        }
        
      })
      .catch((error) => {
        console.error('Error:', error);
        this.style.opacity = '1';
        this.style.pointerEvents = 'auto';
      });
    });
  });
});
</script>




{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Featured product"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sub Heading",
      "default": "Bring called seed first of third give itself now ment"
    },
    {
      "type": "collection",
      "id": "feature_collection",
      "label": "Select Collection to Display"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 3,
      "max": 12,
      "step": 3,
      "label": "Number of products to show",
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Featured Products",
      "category": "Products"
    }
  ]
}
{% endschema %}