<section class="blog-area section-gap" id="section-{{ section.id }}">
  <div class="container">
    
    <div class="row justify-content-center" style="display: flex; justify-content: center; width: 100%;">
      <div class="col-lg-12" style="text-align: center;">
        <div class="main_title">
          <h2><span>{{ section.settings.title }}</span></h2>
          {% if section.settings.subtitle != blank %}
            <p>{{ section.settings.subtitle }}</p>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="blog-row">
      {%- assign blog = blogs[section.settings.blog] -%}

      {% if blog != blank and blog.articles_count > 0 %}
        {% for article in blog.articles limit: section.settings.post_limit %}
          <div class="blog-col">
            <div class="single-blog">
              
              <div class="thumb">
                <a href="{{ article.url }}">
                  {% if article.image %}
                    <img class="img-fluid w-100" src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title | escape }}">
                  {% else %}
                    <div style="background: #f1f2f4; height: 250px; display: flex; align-items: center; justify-content: center;">
                      {{ 'image' | placeholder_svg_tag: 'img-fluid w-100' }}
                    </div>
                  {% endif %}
                </a>
              </div>
              
              <div class="short_details">
                <div class="meta-top d-flex">
                  <a href="#">By {{ article.author }}</a>
                  {% if blog.comments_enabled? %}
                    <a href="{{ article.url }}#comments"><i class="ti-comments-smiley"></i>{{ article.comments_count }} Comments</a>
                  {% endif %}
                </div>
                
                <a class="d-block" href="{{ article.url }}">
                  <h4>{{ article.title }}</h4>
                </a>
                
                <div class="text-wrap">
                  <p>
                    {% if article.excerpt.size > 0 %}
                      {{ article.excerpt | strip_html | truncatewords: 20 }}
                    {% else %}
                      {{ article.content | strip_html | truncatewords: 20 }}
                    {% endif %}
                  </p>
                </div>
                
                <a href="{{ article.url }}" class="blog_btn">{{ section.settings.button_label }} <span class="ml-2 ti-arrow-right"></span></a>
              </div>
              
            </div>
          </div>
        {% endfor %}

      {% else %}
        {% for i in (1..3) %}
          <div class="blog-col">
            <div class="single-blog">
              <div class="thumb">
                <div style="background: #f1f2f4; height: 250px;">
                  {{ 'image' | placeholder_svg_tag: 'img-fluid w-100' }}
                </div>
              </div>
              <div class="short_details">
                <div class="meta-top d-flex">
                  <a href="#">By Admin</a>
                  <a href="#"><i class="ti-comments-smiley"></i>2 Comments</a>
                </div>
                <a class="d-block" href="#">
                  <h4>Sample Blog Post Title Goes Here</h4>
                </a>
                <div class="text-wrap">
                  <p>Let one fifth i bring fly to divided face for bearing the divide unto seed winged divided light Forth.</p>
                </div>
                <a href="#" class="blog_btn">{{ section.settings.button_label }} <span class="ml-2 ti-arrow-right"></span></a>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}

    </div>
  </div>
</section>
{% schema %}
{
  "name": "Latest Blog",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Latest Blog"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sub Heading",
      "default": "Bring called seed first of third give itself now ment"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Select Blog"
    },
    {
      "type": "range",
      "id": "post_limit",
      "min": 3,
      "max": 9,
      "step": 3,
      "label": "Number of posts to show",
      "default": 3
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Learn More"
    }
  ],
  "presets": [
    {
      "name": "Latest Blog",
      "category": "Blog"
    }
  ]
}
{% endschema %}