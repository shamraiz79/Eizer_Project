<section class="inspired_product_area section_gap_bottom_custom" id="section-{{ section.id }}">
  <div class="container">
    
    <div class="row justify-content-center" style="display: flex; justify-content: center; width: 100%;">
      <div class="col-lg-12" style="text-align: center;">
        <div class="main_title">
          <h2><span>{{ section.settings.title }}</span></h2>
          {% if section.settings.subtitle != blank %}
            <p>{{ section.settings.subtitle }}</p>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="inspired-row">
      {%- assign collection = collections[section.settings.inspired_collection] -%}
      
      {% if collection != blank and collection.products_count > 0 %}
        {% for product in collection.products limit: section.settings.product_limit %}
          <div class="inspired-col">
            <div class="single-product">
              <div class="product-img">
                <img class="img-fluid w-100" src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" />
                <div class="p_icon">
                  <a href="{{ product.url }}"><i class="ti-eye"></i></a>
                  <a href="#"><i class="ti-heart"></i></a>
                  <a href="{{ product.url }}"><i class="ti-shopping-cart"></i></a>
                </div>
              </div>
              <div class="product-btm">
                <a href="{{ product.url }}" class="d-block">
                  <h4>{{ product.title }}</h4>
                </a>
                <div class="mt-3">
                  <span class="mr-4">{{ product.price | money }}</span>
                  {% if product.compare_at_price > product.price %}
                    <del>{{ product.compare_at_price | money }}</del>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
        
      {% else %}
        {% for i in (1..8) %}
          <div class="inspired-col">
            <div class="single-product">
              <div class="product-img" style="background: #f1f2f4;">
                {% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
                {{ 'product-' | append: current | placeholder_svg_tag: 'img-fluid w-100' }}
                <div class="p_icon">
                  <a href="#"><i class="ti-eye"></i></a>
                  <a href="#"><i class="ti-heart"></i></a>
                  <a href="#"><i class="ti-shopping-cart"></i></a>
                </div>
              </div>
              <div class="product-btm">
                <a href="#" class="d-block">
                  <h4>Sample Inspired Product</h4>
                </a>
                <div class="mt-3">
                  <span class="mr-4">{{ 2500 | money }}</span>
                  <del>{{ 3500 | money }}</del>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
      
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Inspired Products",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Inspired products"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sub Heading",
      "default": "Bring called seed first of third give itself now ment"
    },
    {
      "type": "collection",
      "id": "inspired_collection",
      "label": "Select Collection to Display"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 4,
      "max": 16,
      "step": 4,
      "label": "Number of products to show",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Inspired Products",
      "category": "Products"
    }
  ]
}
{% endschema %}