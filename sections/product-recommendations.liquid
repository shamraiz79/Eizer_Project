<div 
  class="custom-product-recommendations" 
  data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit=4"
>
  {%- if recommendations.performed and recommendations.products_count > 0 -%}
    <div class="recommendations-container" style="max-width: 1200px; margin: 50px auto; padding: 0 20px;">
      
      <h2 style="text-align: center; margin-bottom: 30px;">{{ section.settings.heading }}</h2>
      
      <div class="recommendations-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 30px;">
        {%- for product in recommendations.products -%}
          <div class="recommendation-card" style="text-align: center; border: 1px solid #eee; padding: 15px; border-radius: 8px;">
            
            <a href="{{ product.url }}" style="display: block; text-decoration: none; color: inherit;">
              <img src="{{ product.featured_image | img_url: '400x400', crop: 'center' }}" alt="{{ product.title }}" style="width: 100%; height: auto; border-radius: 4px; margin-bottom: 15px;">
              <h3 style="font-size: 16px; margin: 0 0 10px 0;">{{ product.title }}</h3>
              <p style="color: #71cd14; font-weight: 600; margin: 0 0 15px 0;">{{ product.price | money }}</p>
            </a>

            <button type="button" class="quick-add-icon-btn" data-variant-id="{{ product.selected_or_first_available_variant.id }}" aria-label="Add to cart">
              <i class="ti-shopping-cart"></i>
            </button>
            
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Product Recommendations",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You May Also Like"
    }
  ],
  "presets": [
    {
      "name": "Product Recommendations"
    }
  ]
}
{% endschema %}

<script>
document.addEventListener('DOMContentLoaded', function() {
  const recommendationsSection = document.querySelector('.custom-product-recommendations');
  if (!recommendationsSection) return;

  // Grab the exact URL Shopify needs from our HTML data attribute
  const url = recommendationsSection.dataset.url;

  // Fetch the fully rendered HTML block from Shopify
  fetch(url)
    .then(response => response.text())
    .then(text => {
      // Convert the text response into a real HTML document
      const html = document.createElement('div');
      html.innerHTML = text;
      
      // Find the specific recommendations div inside the response
      const recommendationsHTML = html.querySelector('.custom-product-recommendations');

      // If Shopify found related products, inject them into our page
      if (recommendationsHTML && recommendationsHTML.innerHTML.trim().length > 0) {
        recommendationsSection.innerHTML = recommendationsHTML.innerHTML;
        
        // We need to re-attach your cart icon Javascript to these new buttons!
        attachQuickAddListeners(recommendationsSection);
      }
    })
    .catch(e => {
      console.error('Error fetching recommendations:', e);
    });
    
    // Function to make sure your Quick Add cart icons work on the dynamically loaded products
    function attachQuickAddListeners(container) {
      const quickAddButtons = container.querySelectorAll('.quick-add-icon-btn');
      quickAddButtons.forEach(button => {
        button.addEventListener('click', function(e) {
          e.preventDefault();
          const variantId = this.getAttribute('data-variant-id');
          if (!variantId) return;

          this.classList.add('is-loading');

          fetch(window.Shopify.routes.root + 'cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 'items': [{ 'id': variantId, 'quantity': 1 }] })
          })
          .then(response => response.json())
          .then(data => {
            this.classList.remove('is-loading');
            if (window.updateCartDrawer) window.updateCartDrawer(); // Updates your drawer math
            const headerCartIcon = document.getElementById('openCartDrawer');
            if (headerCartIcon) headerCartIcon.click(); // Opens your drawer
          })
          .catch((error) => {
            console.error('Error adding to cart:', error);
            this.classList.remove('is-loading');
          });
        });
      });
    }
});
</script>