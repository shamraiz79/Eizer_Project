<section class="banner_area" style="background: #f9f9fa; padding: 60px 0; margin-bottom: 50px;">
  <div class="banner_inner d-flex align-items-center">
    <div class="container">
      <div class="banner_content d-md-flex justify-content-between align-items-center">
        <div class="mb-3 mb-md-0">
          <h2 style="color: #222; font-size: 36px; font-weight: 700;">{{ blog.title }}</h2>
        </div>
        <div class="page_link" style="font-size: 12px; text-transform: uppercase; letter-spacing: 1px;">
          <a href="{{ routes.root_url }}" style="color: #777; text-decoration: none;">Home</a> / 
          <a href="{{ blog.url }}" style="color: #222; font-weight: 500; text-decoration: none;">{{ blog.title }}</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="blog_area section_gap">
  <div class="container">
    <div class="custom-blog-layout">
      
      <div class="custom-blog-main">
        <div class="blog_left_sidebar">
          {% paginate blog.articles by 5 %}
            {% for article in blog.articles %}
              <article class="blog_item">
                <div class="blog_item_img">
                  <a href="{{ article.url }}">
                    {% if article.image %}
                      <img class="card-img rounded-0" src="{{ article.image | image_url: width: 800 }}" alt="{{ article.title }}">
                    {% else %}
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    {% endif %}
                  </a>
                  <div class="blog_item_date">
                    <h3>{{ article.published_at | date: "%d" }}</h3>
                    <p>{{ article.published_at | date: "%b" }}</p>
                  </div>
                </div>

                <div class="blog_details">
                  <a class="d-inline-block text-decoration-none" href="{{ article.url }}">
                    <h2>{{ article.title }}</h2>
                  </a>
                  <p>{{ article.excerpt_or_content | strip_html | truncatewords: 30 }}</p>
                  <ul class="blog-info-link">
                    <li><a href="#"><i class="ti-user"></i> {{ article.author }}</a></li>
                    <li><a href="{{ article.url }}#comments"><i class="ti-comments"></i> {{ article.comments_count }} Comments</a></li>
                  </ul>
                </div>
              </article>
            {% else %}
              <p>No blog posts found. Start writing!</p>
            {% endfor %}

            {% if paginate.pages > 1 %}
              <nav class="blog-pagination justify-content-center d-flex">
                <ul class="pagination">
                  {{ paginate | default_pagination }}
                </ul>
              </nav>
            {% endif %}
          {% endpaginate %}
        </div>
      </div>

      <div class="custom-blog-sidebar">
        <div class="blog_right_sidebar">
          
          <aside class="single_sidebar_widget search_widget">
            <form action="{{ routes.search_url }}">
              <input type="hidden" name="type" value="article">
              <div class="form-group">
                <div class="input-group mb-3">
                  <input type="text" name="q" class="form-control" placeholder="Search Keyword" onfocus="this.placeholder = ''" onblur="this.placeholder = 'Search Keyword'">
                  <div class="input-group-append">
                    <button class="btn" type="submit"><i class="ti-search"></i></button>
                  </div>
                </div>
              </div>
              <button class="button rounded-0 primary-bg text-white w-100 btn_1" type="submit">Search</button>
            </form>
          </aside>

          <aside class="single_sidebar_widget post_category_widget">
            <h4 class="widget_title">Category</h4>
            <ul class="list cat-list">
              {% for tag in blog.all_tags %}
                <li>
                  <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="d-flex">
                    <p>{{ tag }}</p>
                  </a>
                </li>
              {% endfor %}
            </ul>
          </aside>

          <aside class="single_sidebar_widget popular_post_widget">
            <h3 class="widget_title">Recent Post</h3>
            {% for article in blog.articles limit: 5 %}
              <div class="media post_item">
                <img src="{{ article.image | image_url: width: 80, height: 80, crop: 'center' }}" alt="post" style="border-radius: 4px;">
                <div class="media-body">
                  <a href="{{ article.url }}">
                    <h3>{{ article.title | truncatewords: 5 }}</h3>
                  </a>
                  <p>{{ article.published_at | date: "%B %d, %Y" }}</p>
                </div>
              </div>
            {% endfor %}
          </aside>

          <aside class="single_sidebar_widget tag_cloud_widget">
            <h4 class="widget_title">Tag Clouds</h4>
            <ul class="list">
              {% for tag in blog.all_tags %}
                <li><a href="{{ blog.url }}/tagged/{{ tag | handle }}">{{ tag }}</a></li>
              {% endfor %}
            </ul>
          </aside>

          <aside class="single_sidebar_widget instagram_feeds">
            <h4 class="widget_title">Instagram Feeds</h4>
            <ul class="instagram_row flex-wrap">
              <li><a href="#"><img class="img-fluid" src="https://picsum.photos/80/80?random=1" alt=""></a></li>
              <li><a href="#"><img class="img-fluid" src="https://picsum.photos/80/80?random=2" alt=""></a></li>
              <li><a href="#"><img class="img-fluid" src="https://picsum.photos/80/80?random=3" alt=""></a></li>
              <li><a href="#"><img class="img-fluid" src="https://picsum.photos/80/80?random=4" alt=""></a></li>
              <li><a href="#"><img class="img-fluid" src="https://picsum.photos/80/80?random=5" alt=""></a></li>
              <li><a href="#"><img class="img-fluid" src="https://picsum.photos/80/80?random=6" alt=""></a></li>
            </ul>
          </aside>

          <aside class="single_sidebar_widget newsletter_widget">
            <h4 class="widget_title">Newsletter</h4>
            {% form 'customer' %}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <div class="form-group">
                <input type="email" name="contact[email]" class="form-control" placeholder="Enter email" required>
              </div>
              <button class="button rounded-0 primary-bg text-white w-100 btn_1" type="submit">Subscribe</button>
            {% endform %}
          </aside>

        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blog Layout",
  "settings": []
}
{% endschema %}