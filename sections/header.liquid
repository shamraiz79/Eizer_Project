<header class="custom-header-area">
  <div class="custom-header-container">
    <nav class="custom-navbar">
      
      <a class="custom-logo-link" href="{{ routes.root_url }}">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | image_url: width: 250 }}" alt="{{ shop.name }}" />
        {% else %}
          <div class="custom-logo-fallback">
            <div class="custom-logo-circle">
              <span>e</span>
            </div>
            <h2>eiser</h2>
          </div>
        {% endif %}
      </a>
      
      <div class="desktop-nav-container">
        <ul class="custom-desktop-nav-list">
          {%- assign main_menu = section.settings.main_menu -%}
          {%- for link in linklists[main_menu].links -%}
            {%- if link.links != blank -%}
              <li class="custom-nav-item has-dropdown {% if link.active or link.child_active %}active{% endif %}">
                <a href="{{ link.url }}" class="custom-nav-link">
                  {{ link.title }} <span class="dropdown-arrow"></span>
                </a>
                <ul class="custom-dropdown-menu">
                  {%- for childlink in link.links -%}
                    <li class="custom-dropdown-item {% if childlink.active %}active{% endif %}">
                      <a class="custom-dropdown-link" href="{{ childlink.url }}">{{ childlink.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              </li>
            {%- else -%}
              <li class="custom-nav-item {% if link.active %}active{% endif %}">
                <a class="custom-nav-link" href="{{ link.url }}">{{ link.title }}</a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      <div class="right-icons-container">
        <ul class="custom-right-icons-list">
          <li class="custom-icon-item desktop-only"><a href="#" id="SearchTrigger"><i class="ti-search"></i></a></li>
<li class="custom-icon-item">
  <a href="{{ routes.cart_url }}" id="openCartDrawer">
    <i class="ti-shopping-cart"></i>
  </a>
</li>
          <li class="custom-icon-item desktop-only"><a href="{{ routes.account_url }}"><i class="ti-user"></i></a></li>
          <li class="custom-icon-item desktop-only"><a href="/pages/wishlist"><i class="ti-heart"></i></a></li>
          
          <li class="custom-icon-item mobile-hamburger">
            <button class="mobile-menu-trigger" id="openMobileMenu">
              <span class="icon-bar"></span>
              <span class="icon-bar"></span>
              <span class="icon-bar"></span>
            </button>
          </li>
        </ul>
      </div>

    </nav>
  </div>
</header>

<div class="mobile-menu-overlay" id="mobileOverlay"></div>
<div class="mobile-side-drawer" id="mobileDrawer">
  <div class="drawer-header">
    <h4>Menu</h4>
    <button class="close-drawer-btn" id="closeMobileMenu">&times;</button>
  </div>
  
  <div class="drawer-body">
    <ul class="mobile-nav-list">
      {%- for link in linklists[main_menu].links -%}
        {%- if link.links != blank -%}
          <li class="mobile-nav-item has-children">
            <div class="mobile-link-wrapper">
              <a href="{{ link.url }}">{{ link.title }}</a>
              <button class="mobile-submenu-toggle">+</button>
            </div>
            <ul class="mobile-submenu">
              {%- for childlink in link.links -%}
                <li><a href="{{ childlink.url }}">{{ childlink.title }}</a></li>
              {%- endfor -%}
            </ul>
          </li>
        {%- else -%}
          <li class="mobile-nav-item">
            <a href="{{ link.url }}">{{ link.title }}</a>
          </li>
        {%- endif -%}
      {%- endfor -%}
      
      <li class="mobile-nav-item mobile-extra-links-divider">
        <a href="#" id="SearchTriggerMobile"><i class="ti-search custom-icon-spacing"></i> Search</a>
      </li>
      <li class="mobile-nav-item">
        <a href="{{ routes.account_url }}"><i class="ti-user custom-icon-spacing"></i> Account</a>
      </li>
      <li class="mobile-nav-item">
        <a href="/pages/wishlist"><i class="ti-heart custom-icon-spacing"></i> Wishlist</a>
      </li>
    </ul>
  </div>
</div>

{% comment %} JavaScript for Drawer & Accordion {% endcomment %}
<script>
document.addEventListener('DOMContentLoaded', function() {
  const openBtn = document.getElementById('openMobileMenu');
  const closeBtn = document.getElementById('closeMobileMenu');
  const drawer = document.getElementById('mobileDrawer');
  const overlay = document.getElementById('mobileOverlay');

  // Open Mobile Drawer
  if (openBtn) {
    openBtn.addEventListener('click', function(e) {
      e.preventDefault();
      drawer.classList.add('active');
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden'; // Stop background scrolling
    });
  }

  // Close Mobile Drawer
  function closeDrawer() {
    drawer.classList.remove('active');
    overlay.classList.remove('active');
    document.body.style.overflow = ''; // Restore scrolling
  }

  if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
  if (overlay) overlay.addEventListener('click', closeDrawer);

  // Mobile Submenu Accordion Toggles (+ / -)
  const submenuToggles = document.querySelectorAll('.mobile-submenu-toggle');
  submenuToggles.forEach(function(toggle) {
    toggle.addEventListener('click', function(e) {
      e.preventDefault();
      const submenu = this.parentElement.nextElementSibling;
      
      if (submenu.style.display === 'block') {
        submenu.style.display = 'none';
        this.innerHTML = '+';
      } else {
        submenu.style.display = 'block';
        this.innerHTML = '-';
      }
    });
  });
});


// cart icon functionality



document.addEventListener('DOMContentLoaded', function() {
  
  const openCartBtn = document.getElementById('openCartDrawer');
  const closeCartBtn = document.getElementById('closeCartDrawer');
  const cartDrawer = document.getElementById('cartDrawer');
  const cartOverlay = document.getElementById('cartOverlay');
  const cartBody = document.getElementById('cartDrawerBody');
  const cartTotal = document.getElementById('cartDrawerTotal');

  // Function to fetch cart data from Shopify
  function updateCartDrawer() {
    fetch('/cart.js')
      .then(response => response.json())
      .then(cart => {
        
        // Update Total Price (Shopify returns price in cents, so we divide by 100)
        cartTotal.innerHTML = '$' + (cart.total_price / 100).toFixed(2);
        
        // Clear current items
        cartBody.innerHTML = '';
        
        if (cart.item_count === 0) {
          cartBody.innerHTML = '<p class="empty-cart-message">Your cart is currently empty.</p>';
          return;
        }

        // Loop through items and create HTML
        cart.items.forEach(item => {
          let itemHTML = `
            <div class="cart-item">
              <img src="${item.image}" alt="${item.title}" class="cart-item-img">
              <div class="cart-item-details">
                <a href="${item.url}" class="cart-item-title">${item.product_title}</a>
                ${item.variant_title ? `<p class="cart-item-variant">${item.variant_title}</p>` : ''}
                <p class="cart-item-price">$${(item.line_price / 100).toFixed(2)}</p>
                <p class="cart-item-variant">Qty: ${item.quantity}</p>
              </div>
            </div>
          `;
          cartBody.innerHTML += itemHTML;
        });
      })
      .catch(error => console.error('Error fetching cart:', error));
  }

  // Open Drawer Event
  if(openCartBtn) {
    openCartBtn.addEventListener('click', function(e) {
      e.preventDefault(); // Stops it from going to the cart page
      cartDrawer.classList.add('active');
      cartOverlay.classList.add('active');
      document.body.style.overflow = 'hidden'; 
      updateCartDrawer(); // Fetches the latest items every time you open it
    });
  }

  // Close Drawer Event
  function closeCart() {
    cartDrawer.classList.remove('active');
    cartOverlay.classList.remove('active');
    document.body.style.overflow = ''; 
  }

  if(closeCartBtn) closeCartBtn.addEventListener('click', closeCart);
  if(cartOverlay) cartOverlay.addEventListener('click', closeCart);

});

</script>




<div class="cart-drawer-overlay" id="cartOverlay"></div>
<div class="custom-cart-drawer" id="cartDrawer">
  
  <div class="cart-drawer-header">
    <h4>Your Cart</h4>
    <button class="close-cart-btn" id="closeCartDrawer">&times;</button>
  </div>
  
  <div class="cart-drawer-body" id="cartDrawerBody">
    <div class="empty-cart-message">Loading cart...</div>
  </div>
  
  <div class="cart-drawer-footer">
    <div class="cart-subtotal">
      <span>Subtotal:</span>
      <span id="cartDrawerTotal">$0.00</span>
    </div>
    <a href="/checkout" class="custom-checkout-btn">Checkout</a>
    <a href="{{ routes.cart_url }}" class="custom-view-cart-link">View Full Cart</a>
  </div>
  
</div>







{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Store Logo"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Main Menu",
      "default": "main-menu"
    }
  ],
  "presets": [
    {
      "name": "headers"
    }
  ]
}
{% endschema %}