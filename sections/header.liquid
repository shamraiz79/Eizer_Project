<header class="header_area">
  <div class="main_menu">
    <div class="container">
      <nav class="navbar">
        
        <a class="navbar-brand logo_h" href="{{ routes.root_url }}">
          {% if section.settings.logo != blank %}
            <img src="{{ section.settings.logo | image_url: width: 250 }}" alt="{{ shop.name }}" />
          {% else %}
            <div style="display: flex; align-items: center; gap: 8px;">
              <div style="background: var(--primary-color); border-radius: 50%; width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;">
                <span style="color: #fff; font-weight: bold; font-size: 20px; font-style: italic;">e</span>
              </div>
              <h2 style="margin: 0; font-weight: 800; color: #222; font-size: 28px; letter-spacing: -1px;">eiser</h2>
            </div>
          {% endif %}
        </a>
        
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent">
          <span class="icon-bar"></span><span class="icon-bar"></span><span class="icon-bar"></span>
        </button>
        
        <div class="collapse navbar-collapse offset" id="navbarSupportedContent">
          <div class="row w-100 mr-0">
            
            <div class="col-lg-7 pr-0 center-nav-container">
          <div class="col-lg-7 pr-0 center-nav-container">
  <ul class="nav navbar-nav center_nav">
    
    {%- assign main_menu = section.settings.main_menu -%}
    
    {%- for link in linklists[main_menu].links -%}
      
      {%- if link.links != blank -%}
        
        <li class="nav-item submenu dropdown {% if link.active or link.child_active %}active{% endif %}">
          <a href="{{ link.url }}" class="nav-link dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">
            {{ link.title }}
          </a>
          <ul class="dropdown-menu">
            {%- for childlink in link.links -%}
              <li class="nav-item {% if childlink.active %}active{% endif %}">
                <a class="nav-link" href="{{ childlink.url }}">{{ childlink.title }}</a>
              </li>
            {%- endfor -%}
          </ul>
        </li>
        
      {%- else -%}
        
        <li class="nav-item {% if link.active %}active{% endif %}">
          <a class="nav-link" href="{{ link.url }}">{{ link.title }}</a>
        </li>
        
      {%- endif -%}
      
    {%- endfor -%}

  </ul>
</div>

            <div class="col-lg-5 pr-0 right-icons-container">
              <ul class="nav navbar-nav navbar-right right_nav">
              <li class="nav-item">
                 <a href="#" class="icons" id="SearchTrigger"><i class="ti-search"></i></a>
                 </li>
                <li class="nav-item"><a href="{{ routes.cart_url }}" class="icons"><i class="ti-shopping-cart"></i></a></li>
                <li class="nav-item"><a href="{{ routes.account_url }}" class="icons"><i class="ti-user"></i></a></li>
                <li class="nav-item"><a href="/pages/wishlist" class="icons"><i class="ti-heart"></i></a></li>
              </ul>
            </div>

          </div>
        </div>
      </nav>
    </div>
  </div>
</header>
{% comment %} java script for hambuger menu {% endcomment %}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    var togglerBtn = document.querySelector('.navbar-toggler');
    var mobileMenu = document.getElementById('navbarSupportedContent');

    if (togglerBtn && mobileMenu) {
      togglerBtn.addEventListener('click', function(e) {
        e.preventDefault();
        // This targets the specific ID of your menu and forces our new CSS class
        mobileMenu.classList.toggle('force-mobile-open'); 
      });
    }
  });
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Store Logo"
    },
    {
  "type": "link_list",
  "id": "main_menu",
  "label": "Main Menu",
  "default": "main-menu"
}
  ],
  "presets": [
    {
      "name": "headers"
      
    }
  ]
}
{% endschema %}